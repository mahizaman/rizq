---
---

<footer class="bg-rizq-charcoal pt-24 pb-10 px-8 md:px-16 relative overflow-hidden">
  
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #D4A84B 1px, transparent 1px); background-size: 50px 50px;"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <!-- Top section -->
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      
      <!-- Logo & Tagline -->
      <div class="md:col-span-2">
        <img src="/logo.png" alt="Rizq" class="h-24 mb-6 brightness-0 invert opacity-90" />
        <p class="text-rizq-cream/70 font-serif italic text-xl mb-4 max-w-md">
          Delightfully Delicious — where culinary excellence meets flawless execution.
        </p>
        <p class="text-rizq-cream/50 text-sm leading-relaxed max-w-md">
          Premium catering for the families and corporations who demand nothing less than perfection.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-rizq-gold uppercase text-xs tracking-[0.3em] mb-6">Explore</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-rizq-cream/70 hover:text-rizq-gold transition-colors">Home</a></li>
          <li><a href="/services" class="text-rizq-cream/70 hover:text-rizq-gold transition-colors">Services</a></li>
          <li><a href="/menu" class="text-rizq-cream/70 hover:text-rizq-gold transition-colors">The Menu</a></li>
          <li><a href="/gallery" class="text-rizq-cream/70 hover:text-rizq-gold transition-colors">Gallery</a></li>
          <li><a href="/book-event" class="text-rizq-cream/70 hover:text-rizq-gold transition-colors">Book an Event</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-rizq-gold uppercase text-xs tracking-[0.3em] mb-6">Get in Touch</h4>
        <ul class="space-y-3 text-rizq-cream/70 text-sm">
          <li>House 254, Road 3<br/>Baridhara DOHS<br/>Dhaka, Bangladesh</li>
          <li><a href="https://wa.me/8801XXXXXXXXX" class="hover:text-rizq-gold transition-colors">WhatsApp: +880 1XXX-XXXXXX</a></li>
          <li><a href="mailto:hello@rizq.com" class="hover:text-rizq-gold transition-colors">hello@rizq.com</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-[1px] bg-gradient-to-r from-transparent via-rizq-gold/30 to-transparent mb-8"></div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-rizq-cream/40 text-xs uppercase tracking-[0.3em]">© 2025 Rizq Catering. All rights reserved.</p>
      <p class="text-rizq-cream/40 text-xs italic">Crafted with passion in Dhaka.</p>
    </div>
  </div>
</footer>
