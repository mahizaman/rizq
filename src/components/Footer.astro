---
import { SITE, NAV_LINKS } from "../config/site.js";
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMessage)}`;
const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-ivory pt-16 pb-8 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <img src="/rizq-logo.png" alt="Rizq" class="h-16 mb-4 brightness-0 invert" />
        <p class="text-ivory/70 leading-relaxed mb-5 max-w-md">
          Bangladesh's premier luxury catering — delivering uncompromising culinary excellence for the most discerning hosts.
        </p>
        <p class="text-ivory/60 text-sm leading-relaxed">
          {SITE.address}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-display text-xl text-white mb-5">Explore</h4>
        <ul class="space-y-3">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-ivory/70 hover:text-crimson transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/book" class="text-ivory/70 hover:text-crimson transition-colors">
              Book an Event
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display text-xl text-white mb-5">Connect</h4>
        <ul class="space-y-3">
          <li>
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-ivory/70 hover:text-crimson transition-colors flex items-center gap-2">
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`mailto:${SITE.email}`} class="text-ivory/70 hover:text-crimson transition-colors">
              {SITE.email}
            </a>
          </li>
          <li>
            <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" class="text-ivory/70 hover:text-crimson transition-colors">
              Facebook
            </a>
          </li>
          <li>
            <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" class="text-ivory/70 hover:text-crimson transition-colors">
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-ivory/10 pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-ivory/50">
      <p>© {year} Rizq Catering. All rights reserved.</p>
      <p class="italic">Delightfully Delicious.</p>
    </div>
  </div>
</footer>
