---
const faqs = [
  {
    q: "What's the minimum and maximum number of guests Rizq caters for?",
    a: "We cater intimate gatherings starting from 50 guests and have the operational capacity to flawlessly serve up to 10,000 guests at royal-scale events — without compromising quality or service.",
  },
  {
    q: "How far in advance should I book Rizq for my event?",
    a: "For weddings and large galas, we recommend booking 2-3 months in advance to secure your date and allow ample time for bespoke menu curation. For corporate events or smaller social gatherings, 3-4 weeks is typically sufficient. Premium dates may book out earlier.",
  },
  {
    q: "Do you offer customized menus or only fixed packages?",
    a: "We specialize in fully tailored culinary journeys. While we have signature Best Sellers, every menu is curated to reflect your event's personal vision — whether traditional Bengali, fusion, or international dietary accommodations.",
  },
  {
    q: "What's included in the catering service?",
    a: "Our standard offering includes premium ingredients, expert chefs, elegant presentation, trained waitstaff, full event coordination, serving equipment, and seamless logistics. Custom add-ons like decor, live counters, and specialty stations are available on request.",
  },
  {
    q: "Can you accommodate dietary restrictions and international guests?",
    a: "Absolutely. We regularly cater for guests with halal, vegetarian, vegan, gluten-free, and other specific dietary needs — including international corporate delegates with refined or restricted palates.",
  },
  {
    q: "What's your pricing structure?",
    a: "Pricing is transparent and depends on menu selection, guest count, service level, and event complexity. We provide detailed, itemized quotes after understanding your vision. Contact us via WhatsApp or our booking form for a personalized estimate.",
  },
  {
    q: "Do you provide service outside Dhaka?",
    a: "Yes. While our base is in Dhaka, we have successfully executed large-scale events across Bangladesh. Travel and logistics are accounted for transparently in your quote.",
  },
  {
    q: "How do I book Rizq for my event?",
    a: "The fastest way is to click 'Book an Event' or chat with us directly on WhatsApp. Share your event date, guest count, and vision — and our team will reach out within 24 hours to begin curating your experience.",
  },
];
---

<section class="py-20 lg:py-28 px-6 bg-ivory">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-crimson uppercase tracking-[0.25em] text-sm font-semibold mb-3">FAQ</p>
      <h2 class="font-display text-4xl md:text-5xl text-royal mb-4">Frequently Asked</h2>
      <p class="text-charcoal-light max-w-2xl mx-auto text-lg">
        Answers to what discerning hosts most often ask.
      </p>
    </div>

    <div class="space-y-3">
      {
        faqs.map((f, i) => (
          <details class="group bg-white rounded-xl border border-ivory-dark overflow-hidden hover:shadow-md transition-shadow">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
              <h3 class="font-display text-lg md:text-xl text-royal pr-4">
                {f.q}
              </h3>
              <span class="shrink-0 w-8 h-8 rounded-full bg-ivory flex items-center justify-center text-royal group-open:bg-crimson group-open:text-white transition-colors">
                <svg class="w-4 h-4 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-charcoal-light leading-relaxed">
              {f.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
