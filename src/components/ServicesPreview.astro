---
const services = [
  {
    title: "Wedding Ceremonies",
    subtitle: "Grandeur, Perfectly Executed",
    description: "From intimate Mehendis of 50 to royal Walimas of 10,000, we deliver flawless logistical mastery and authentic Kacchi heritage.",
    href: "/services#weddings",
    icon: "💍",
  },
  {
    title: "Social Events",
    subtitle: "Exclusive Hosting, Refined",
    description: "Anniversary galas, family reunions, milestone celebrations — bespoke menus for society's most discerning hosts.",
    href: "/services#social",
    icon: "🥂",
  },
  {
    title: "Corporate Events",
    subtitle: "Boardroom Prestige",
    description: "C-suite dining, product launches, annual galas — culinary professionalism that reflects your brand's market position.",
    href: "/services#corporate",
    icon: "🏛️",
  },
  {
    title: "Industrial Catering",
    subtitle: "Excellence at Scale",
    description: "Up to 10,000 premium meals daily for top-tier corporations and institutions — without compromising quality.",
    href: "/services#industrial",
    icon: "🏭",
  },
];
---

<section class="py-20 lg:py-28 px-6 bg-ivory">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-crimson uppercase tracking-[0.25em] text-sm font-semibold mb-3">Our Services</p>
      <h2 class="font-display text-4xl md:text-5xl text-royal mb-4">Catering Without Compromise</h2>
      <p class="text-charcoal-light max-w-2xl mx-auto text-lg">
        Whatever the scale, whatever the occasion — we deliver perfection.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        services.map((s) => (
          <a
            href={s.href}
            class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 border border-ivory-dark hover:-translate-y-2"
          >
            <div class="text-5xl mb-5">{s.icon}</div>
            <h3 class="font-display text-2xl text-royal mb-2 group-hover:text-crimson transition-colors">
              {s.title}
            </h3>
            <p class="text-crimson text-sm font-semibold uppercase tracking-wider mb-4">
              {s.subtitle}
            </p>
            <p class="text-charcoal-light leading-relaxed mb-5">{s.description}</p>
            <span class="inline-flex items-center gap-2 text-royal font-semibold group-hover:gap-3 transition-all">
              Learn more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
