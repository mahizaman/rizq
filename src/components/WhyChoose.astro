---
const pillars = [
  {
    num: "01",
    title: "Uncompromising Quality & Freshness",
    body: "From the finest aromatic rice for our signature Kacchi Gourmet to premium cuts of meat and locally sourced produce, we procure only the highest-grade ingredients. We never compromise on authenticity.",
  },
  {
    num: "02",
    title: "Bespoke Culinary Curation",
    body: "Moving beyond rigid standard packages, we design fully tailored culinary journeys. From traditional Bengali feasts to contemporary fusion or specific dietary accommodations for international guests.",
  },
  {
    num: "03",
    title: "Masterful, White-Glove Service",
    body: "Managed by a leadership team with top-tier corporate acumen, our highly trained waitstaff, chefs, and coordinators bring absolute professionalism — anticipating needs before they're voiced.",
  },
  {
    num: "04",
    title: "Scalable Excellence & Transparent Prestige",
    body: "True luxury is the ability to deliver perfection at any scale. From intimate VIP gatherings of 50 to royal-scale events of 10,000 — transparent, competitive pricing, magnificent guest experiences.",
  },
];
---

<section class="py-20 lg:py-28 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-crimson uppercase tracking-[0.25em] text-sm font-semibold mb-3">Why Choose Us</p>
      <h2 class="font-display text-4xl md:text-5xl text-royal mb-4">Why Choose Rizq?</h2>
      <p class="text-charcoal-light max-w-2xl mx-auto text-lg">
        Four pillars that define every event we touch.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {
        pillars.map((p) => (
          <div class="relative bg-ivory rounded-2xl p-8 lg:p-10 hover:shadow-xl transition-all border border-ivory-dark group">
            <span class="absolute top-6 right-6 font-display text-7xl text-royal/10 group-hover:text-crimson/20 transition-colors">
              {p.num}
            </span>
            <h3 class="font-display text-2xl lg:text-3xl text-royal mb-4 relative z-10">
              {p.title}
            </h3>
            <p class="text-charcoal-light leading-relaxed relative z-10">{p.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
