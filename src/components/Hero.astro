---
import { SITE } from "../config/site.js";
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMessage)}`;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-charcoal">
  <!-- Background image (more visible) -->
  <div class="absolute inset-0 z-0">
    <img
      src="/kacchi-hero.jpg"
      alt=""
      class="w-full h-full object-cover scale-105 animate-slow-zoom"
      onerror="this.style.display='none'"
    />
    <!-- Cinematic vignette gradient: dark edges, visible center -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_transparent_0%,_rgba(15,17,25,0.35)_45%,_rgba(15,17,25,0.85)_100%)]"></div>
    <!-- Bottom fade for content readability -->
    <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-charcoal via-charcoal/70 to-transparent"></div>
  </div>

  <!-- CSS Smoke trails (right side, rising) -->
  <div class="absolute right-[15%] bottom-[20%] z-10 pointer-events-none hidden md:block">
    <div class="relative w-40 h-64">
      <span class="smoke-puff smoke-1"></span>
      <span class="smoke-puff smoke-2"></span>
      <span class="smoke-puff smoke-3"></span>
      <span class="smoke-puff smoke-4"></span>
      <span class="smoke-puff smoke-5"></span>
    </div>
  </div>

  <!-- Left side smoke trail (mobile + desktop) -->
  <div class="absolute left-[12%] bottom-[15%] z-10 pointer-events-none">
    <div class="relative w-32 h-56">
      <span class="smoke-puff smoke-2"></span>
      <span class="smoke-puff smoke-4"></span>
      <span class="smoke-puff smoke-1"></span>
    </div>
  </div>

  <!-- Decorative top accent -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-[2px] bg-gradient-to-r from-transparent via-crimson/60 to-transparent"></div>

  <!-- Hero content -->
  <div class="relative z-20 text-center px-6 max-w-5xl mx-auto py-24">
    <!-- Tagline with lines -->
    <div class="flex items-center justify-center gap-4 mb-8 opacity-0 animate-fade-in-up" style="animation-delay: 0.1s;">
      <span class="h-[1px] w-12 bg-crimson"></span>
      <p class="text-crimson uppercase tracking-[0.4em] text-xs md:text-sm font-semibold">
        {SITE.tagline}
      </p>
      <span class="h-[1px] w-12 bg-crimson"></span>
    </div>

    <!-- Main heading -->
    <h1 class="font-display text-white text-5xl md:text-7xl lg:text-8xl font-medium leading-[1.05] mb-6 drop-shadow-2xl opacity-0 animate-fade-in-up" style="animation-delay: 0.3s;">
      At <span class="text-crimson">Rizq</span>,
      <br />
      we bring flavors
      <br />
      <span class="italic font-light">to life.</span>
    </h1>

    <!-- Subheading -->
    <p class="text-ivory/80 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed drop-shadow-lg opacity-0 animate-fade-in-up" style="animation-delay: 0.5s;">
      Bangladesh's premier luxury catering — from intimate VIP gatherings to royal-scale events of <span class="text-white font-semibold">10,000 guests</span>.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center opacity-0 animate-fade-in-up" style="animation-delay: 0.7s;">
      <a
        href="/book"
        class="group inline-flex items-center justify-center gap-2 bg-crimson hover:bg-crimson-dark text-white font-semibold px-8 py-4 rounded-full transition-all shadow-2xl shadow-crimson/40 hover:shadow-crimson/60 hover:scale-105"
      >
        Book an Event
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md text-white font-semibold px-8 py-4 rounded-full transition-all border border-white/30 hover:border-white/60"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Chat on WhatsApp
      </a>
    </div>

    <!-- Stats strip (luxury social proof) -->
    <div class="grid grid-cols-3 gap-4 md:gap-12 max-w-3xl mx-auto mt-16 pt-10 border-t border-white/15 opacity-0 animate-fade-in-up" style="animation-delay: 0.9s;">
      <div class="text-center">
        <p class="font-display text-3xl md:text-5xl text-white mb-1">10K+</p>
        <p class="text-ivory/60 text-xs md:text-sm uppercase tracking-wider">Guests Served</p>
      </div>
      <div class="text-center border-x border-white/15">
        <p class="font-display text-3xl md:text-5xl text-white mb-1">500+</p>
        <p class="text-ivory/60 text-xs md:text-sm uppercase tracking-wider">Events Catered</p>
      </div>
      <div class="text-center">
        <p class="font-display text-3xl md:text-5xl text-white mb-1">100%</p>
        <p class="text-ivory/60 text-xs md:text-sm uppercase tracking-wider">Premium Quality</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <div class="w-7 h-12 border-2 border-white/40 rounded-full flex items-start justify-center p-2">
      <span class="w-1.5 h-2.5 bg-white/70 rounded-full animate-scroll-dot"></span>
    </div>
  </div>
</section>

<style>
  /* Smoke puffs */
  .smoke-puff {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 60px;
    height: 60px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.15) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(8px);
    opacity: 0;
    transform: translateX(-50%);
  }

  .smoke-1 { animation: smoke-rise 6s ease-out infinite; animation-delay: 0s; }
  .smoke-2 { animation: smoke-rise 7s ease-out infinite; animation-delay: 1.2s; left: 30%; }
  .smoke-3 { animation: smoke-rise 8s ease-out infinite; animation-delay: 2.4s; left: 70%; }
  .smoke-4 { animation: smoke-rise 6.5s ease-out infinite; animation-delay: 3.6s; left: 40%; }
  .smoke-5 { animation: smoke-rise 7.5s ease-out infinite; animation-delay: 4.8s; left: 60%; }

  @keyframes smoke-rise {
    0% {
      transform: translateX(-50%) translateY(0) scale(0.6);
      opacity: 0;
    }
    15% {
      opacity: 0.7;
    }
    100% {
      transform: translateX(-50%) translateY(-250px) scale(3);
      opacity: 0;
    }
  }

  /* Slow zoom on hero image */
  @keyframes slow-zoom {
    0% { transform: scale(1.05); }
    50% { transform: scale(1.12); }
    100% { transform: scale(1.05); }
  }
  .animate-slow-zoom {
    animation: slow-zoom 20s ease-in-out infinite;
  }

  /* Fade in up */
  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.9s ease-out forwards;
  }

  /* Scroll indicator dot */
  @keyframes scroll-dot {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(8px); opacity: 0.3; }
  }
  .animate-scroll-dot {
    animation: scroll-dot 1.8s ease-in-out infinite;
  }
</style>
