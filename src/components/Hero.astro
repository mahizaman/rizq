---
---

<section class="relative h-screen w-full overflow-hidden bg-rizq-charcoal" id="hero">
  
  <!-- Background Video -->
  <div class="absolute inset-0 z-0">
    <video 
      autoplay 
      muted 
      loop 
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
      id="heroVideo"
    >
      <source src="https://cdn.coverr.co/videos/coverr-cooking-a-meal-3633/1080p.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-rizq-charcoal/70 via-rizq-charcoal/50 to-rizq-charcoal/90"></div>
    <!-- Vignette -->
    <div class="absolute inset-0" style="background: radial-gradient(circle, transparent 30%, rgba(15,23,42,0.7) 100%);"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6">
    
    <!-- Top tagline -->
    <div class="reveal mb-6 flex items-center gap-4">
      <span class="h-[1px] w-12 bg-rizq-gold"></span>
      <span class="text-rizq-gold text-xs uppercase tracking-[0.4em] font-medium">Delightfully Delicious</span>
      <span class="h-[1px] w-12 bg-rizq-gold"></span>
    </div>

    <!-- Main Heading -->
    <h1 class="reveal heading-display text-rizq-cream text-5xl md:text-7xl lg:text-8xl max-w-5xl mb-8" id="heroHeading">
      At <span class="italic text-gradient-gold">Rizq</span>,<br/>
      we bring flavors to life<br/>
      <span class="font-serif italic text-4xl md:text-6xl lg:text-7xl">& create moments to remember.</span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal text-rizq-cream/80 text-lg md:text-xl font-serif italic max-w-2xl mb-12">
      Premium luxury catering — from intimate gatherings of 50 to royal galas of 10,000.
    </p>

    <!-- CTAs -->
    <div class="reveal flex flex-col sm:flex-row gap-6 items-center">
      <a href="/book-event" class="magnetic px-10 py-4 bg-rizq-red text-white uppercase tracking-[0.2em] text-sm font-semibold hover:shadow-[0_15px_40px_rgba(220,38,38,0.5)] transition-all duration-300">
        Book an Event
      </a>
      <a href="/menu" class="magnetic px-10 py-4 border border-rizq-gold text-rizq-gold uppercase tracking-[0.2em] text-sm font-semibold hover:bg-rizq-gold hover:text-rizq-charcoal transition-all duration-300">
        Explore Menu
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
    <span class="text-rizq-cream/60 text-xs uppercase tracking-[0.3em]">Scroll</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-rizq-gold to-transparent animate-pulse"></div>
  </div>

  <!-- Decorative side text -->
  <div class="absolute left-6 top-1/2 -translate-y-1/2 -rotate-90 origin-left text-rizq-gold/40 text-xs uppercase tracking-[0.5em] hidden md:block">
    Est. Premium Catering
  </div>
  <div class="absolute right-6 top-1/2 -translate-y-1/2 rotate-90 origin-right text-rizq-gold/40 text-xs uppercase tracking-[0.5em] hidden md:block">
    Dhaka • Bangladesh
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  // Parallax hero scale on scroll
  gsap.to('#heroVideo', {
    scale: 1.3,
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true,
    }
  });

  // Heading letter split & reveal
  setTimeout(() => {
    const heading = document.getElementById('heroHeading');
    if (heading) {
      gsap.from(heading, {
        y: 80,
        opacity: 0,
        duration: 1.5,
        delay: 2.5,
        ease: 'expo.out'
      });
    }
  }, 100);
</script>
