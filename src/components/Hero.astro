---
import { SITE } from "../config/site.js";
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMessage)}`;
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-gradient-to-br from-charcoal via-royal-dark to-charcoal">
  <!-- Background image with dark overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="/kacchi-hero.jpg"
      alt=""
      class="w-full h-full object-cover opacity-50"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal/60 via-charcoal/40 to-charcoal/80"></div>
  </div>

  <!-- CSS Smoke animation (centered above) -->
  <div class="absolute left-1/2 top-1/4 -translate-x-1/2 z-10 pointer-events-none">
    <div class="relative w-32 h-32">
      <span class="absolute left-1/2 bottom-0 w-4 h-4 -translate-x-1/2 rounded-full bg-white/30 blur-md animate-smoke-1"></span>
      <span class="absolute left-1/3 bottom-0 w-5 h-5 rounded-full bg-white/25 blur-md animate-smoke-2"></span>
      <span class="absolute left-2/3 bottom-0 w-4 h-4 rounded-full bg-white/20 blur-md animate-smoke-3"></span>
      <span class="absolute left-1/2 bottom-2 w-3 h-3 -translate-x-1/2 rounded-full bg-white/30 blur-sm animate-smoke-2"></span>
    </div>
  </div>

  <!-- Hero content -->
  <div class="relative z-20 text-center px-6 max-w-5xl mx-auto">
    <p class="text-crimson uppercase tracking-[0.3em] text-sm md:text-base mb-6 animate-fade-in">
      {SITE.tagline}
    </p>
    <h1 class="font-display text-white text-4xl md:text-6xl lg:text-7xl font-semibold leading-tight mb-8 text-balance animate-fade-up">
      At Rizq, we bring flavors to life
      <span class="block text-crimson italic mt-2">& create moments to remember.</span>
    </h1>
    <p class="text-ivory/80 text-lg md:text-xl max-w-2xl mx-auto mb-10 animate-fade-up" style="animation-delay: 0.2s;">
      Bangladesh's premier luxury catering — from intimate VIP gatherings to royal-scale events of 10,000 guests.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up" style="animation-delay: 0.4s;">
      <a
        href="/book"
        class="inline-flex items-center justify-center gap-2 bg-crimson hover:bg-crimson-dark text-white font-semibold px-8 py-4 rounded-full transition-all shadow-xl hover:shadow-2xl hover:scale-105"
      >
        Book an Event
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur text-white font-semibold px-8 py-4 rounded-full transition-all border border-white/30"
      >
        Chat on WhatsApp
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <svg class="w-6 h-6 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
