---
import { NAV_LINKS } from "../config/site.js";
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-ivory/90 backdrop-blur-md border-b border-ivory-dark"
>
  <nav class="max-w-7xl mx-auto px-6 lg:px-10 py-3 flex items-center justify-between">
    <!-- Logo -->
   <a href="/" class="flex items-center gap-2 shrink-0">
  <img
    src="/rizq-logo.png"
    alt="Rizq"
    class="h-10 md:h-12 w-auto max-w-[140px] md:max-w-[180px] object-contain"
  />
</a>


    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-8">
      {
        NAV_LINKS.map((link) => (
          <li class="relative group">
            {link.dropdown ? (
              <>
                <a
                  href={link.href}
                  class="text-charcoal hover:text-royal font-medium transition-colors flex items-center gap-1"
                >
                  {link.label}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <ul class="absolute top-full left-0 mt-3 w-64 bg-white shadow-xl rounded-lg overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 border border-ivory-dark">
                  {link.dropdown.map((sub) => (
                    <li>
                      <a
                        href={sub.href}
                        class="block px-5 py-3 text-charcoal hover:bg-ivory hover:text-royal transition-colors"
                      >
                        {sub.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={link.href}
                class="text-charcoal hover:text-royal font-medium transition-colors"
              >
                {link.label}
                {link.comingSoon && (
                  <span class="ml-1 text-xs bg-ivory-dark text-charcoal-light px-2 py-0.5 rounded-full">
                    Soon
                  </span>
                )}
              </a>
            )}
          </li>
        ))
      }
    </ul>

    <!-- CTA Button (desktop) -->
    <a
      href="/book"
      class="hidden lg:inline-flex items-center gap-2 bg-crimson hover:bg-crimson-dark text-white font-semibold px-6 py-3 rounded-full transition-all shadow-md hover:shadow-lg hover:scale-105"
    >
      Book an Event
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button
      id="mobile-toggle"
      class="lg:hidden p-2 text-charcoal"
      aria-label="Toggle menu"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-ivory border-t border-ivory-dark"
  >
    <ul class="px-6 py-4 space-y-1">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="block py-3 text-charcoal hover:text-royal font-medium border-b border-ivory-dark/50"
            >
              {link.label}
              {link.comingSoon && (
                <span class="ml-2 text-xs bg-ivory-dark text-charcoal-light px-2 py-0.5 rounded-full">
                  Soon
                </span>
              )}
            </a>
            {link.dropdown && (
              <ul class="pl-4 pb-2">
                {link.dropdown.map((sub) => (
                  <li>
                    <a
                      href={sub.href}
                      class="block py-2 text-sm text-charcoal-light hover:text-royal"
                    >
                      — {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
      <li class="pt-3">
        <a
          href="/book"
          class="block text-center bg-crimson hover:bg-crimson-dark text-white font-semibold px-6 py-3 rounded-full transition-all"
        >
          Book an Event →
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");

  // Toggle menu open/close on hamburger click
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });

  // Auto-close menu when any link inside it is clicked
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
    });
  });

  // Add shadow to navbar on scroll
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navbar?.classList.add("shadow-md");
    } else {
      navbar?.classList.remove("shadow-md");
    }
  });
</script>

