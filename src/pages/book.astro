---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config/site.js";
const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMessage)}`;
---

<Layout title="Book an Event — Rizq Catering">
  <section class="pt-32 pb-20 px-6 bg-gradient-to-b from-royal to-royal-dark text-white text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-crimson uppercase tracking-[0.3em] text-sm font-semibold mb-4">Book an Event</p>
      <h1 class="font-display text-4xl md:text-6xl mb-6 leading-tight">
        Let's Create Something Unforgettable
      </h1>
      <p class="text-ivory/80 text-lg md:text-xl max-w-2xl mx-auto">
        Share your vision — our team will reach out within 24 hours to begin curating your experience.
      </p>
    </div>
  </section>

  <section class="py-16 px-6 bg-ivory">
    <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-xl p-8 md:p-12 border border-ivory-dark">
      <form
  name="book-event"
  method="POST"
  action="/thank-you"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-6"
>

        <input type="hidden" name="form-name" value="book-event" />
        <p class="hidden">
          <label>Don't fill: <input name="bot-field" /></label>
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Full Name *</label>
            <input
              type="text"
              name="name"
              required
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Phone *</label>
            <input
              type="tel"
              name="phone"
              required
              placeholder="01XXXXXXXXX"
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent"
            />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Email</label>
            <input
              type="email"
              name="email"
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent"
                    <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Email</label>
            <input
              type="email"
              name="email"
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">WhatsApp (if different)</label>
            <input
              type="tel"
              name="whatsapp"
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent"
            />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Event Type *</label>
            <select
              name="event_type"
              required
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent bg-white"
            >
              <option value="">Select an event type</option>
              <option>Wedding — Mehendi</option>
              <option>Wedding — Holud</option>
              <option>Wedding — Walima / Reception</option>
              <option>Anniversary / Family Gala</option>
              <option>Corporate Event</option>
              <option>Product Launch</option>
              <option>Industrial / Daily Catering</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Event Date</label>
            <input
              type="date"
              name="event_date"
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent"
            />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Estimated Guest Count *</label>
            <select
              name="guest_count"
              required
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent bg-white"
            >
              <option value="">Select guest range</option>
              <option>50 – 200</option>
              <option>200 – 500</option>
              <option>500 – 1,000</option>
              <option>1,000 – 3,000</option>
              <option>3,000 – 5,000</option>
              <option>5,000 – 10,000</option>
              <option>10,000+</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-charcoal mb-2">Venue (if known)</label>
            <input
              type="text"
              name="venue"
              placeholder="e.g. Radisson Dhaka"
              class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-charcoal mb-2">Tell us about your vision</label>
          <textarea
            name="message"
            rows="5"
            placeholder="Cuisine preferences, dietary needs, special requests, themes…"
            class="w-full px-4 py-3 border border-ivory-dark rounded-lg focus:outline-none focus:ring-2 focus:ring-royal focus:border-transparent resize-none"
          ></textarea>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <button
            type="submit"
            class="flex-1 inline-flex items-center justify-center gap-2 bg-crimson hover:bg-crimson-dark text-white font-semibold px-8 py-4 rounded-full transition-all shadow-md hover:shadow-xl hover:scale-[1.02]"
          >
            Submit Inquiry →
          </button>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 inline-flex items-center justify-center gap-2 bg-white border-2 border-royal text-royal hover:bg-royal hover:text-white font-semibold px-8 py-4 rounded-full transition-all"
          >
            Prefer WhatsApp?
          </a>
        </div>

        <p class="text-center text-sm text-charcoal-light pt-2">
          We respect your privacy. Your details will only be used to respond to your inquiry.
        </p>
      </form>
    </div>
  </section>
</Layout>
    
