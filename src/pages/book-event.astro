---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book an Event — Rizq Catering">
  <Navbar />

  <!-- Hero -->
  <section class="relative min-h-screen bg-rizq-charcoal pt-32 pb-20 overflow-hidden">
    
    <!-- Decorative background -->
    <div class="absolute inset-0 opacity-10" style="background-image: url('https://images.unsplash.com/photo-1519741497674-611481863552?w=1920&q=80'); background-size: cover; background-position: center;"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-rizq-charcoal via-rizq-charcoal/95 to-rizq-blue/40"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 md:px-12 grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left: Info -->
      <div>
        <div class="reveal flex items-center gap-4 mb-6">
          <span class="h-[1px] w-12 bg-rizq-gold"></span>
          <span class="text-rizq-gold text-xs uppercase tracking-[0.4em]">Reserve Your Date</span>
        </div>
        
        <h1 class="reveal heading-display text-rizq-cream text-5xl md:text-7xl mb-8">
          Let's create<br/>
          <span class="italic text-gradient-gold">unforgettable</span><br/>
          moments.
        </h1>

        <p class="reveal text-rizq-cream/70 font-serif italic text-xl mb-12 max-w-lg">
          From intimate gatherings to royal galas — share your vision and our team will reach out within 24 hours.
        </p>

        <!-- Quick Contact -->
        <div class="reveal space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-rizq-gold/10 border border-rizq-gold/30 flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" fill="none" stroke="#D4A84B" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="text-rizq-gold text-xs uppercase tracking-[0.2em] mb-1">Visit</div>
              <div class="text-rizq-cream">House 254, Road 3, Baridhara DOHS, Dhaka</div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-rizq-gold/10 border border-rizq-gold/30 flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" fill="none" stroke="#D4A84B" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div>
              <div class="text-rizq-gold text-xs uppercase tracking-[0.2em] mb-1">Call</div>
              <a href="tel:+8801XXXXXXXXX" class="text-rizq-cream hover:text-rizq-gold transition-colors">+880 1XXX-XXXXXX</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-rizq-gold/10 border border-rizq-gold/30 flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" fill="none" stroke="#D4A84B" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="text-rizq-gold text-xs uppercase tracking-[0.2em] mb-1">Email</div>
              <a href="mailto:hello@rizq.com" class="text-rizq-cream hover:text-rizq-gold transition-colors">hello@rizq.com</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="reveal bg-rizq-charcoal-soft/80 backdrop-blur-md border border-rizq-gold/20 p-8 md:p-12">
        <h2 class="heading-display text-3xl text-rizq-cream mb-2">Tell us about your event</h2>
        <p class="text-rizq-cream/60 text-sm mb-8 font-serif italic">Every detail crafted to perfection.</p>

        <form name="book-event" method="POST" data-netlify="true" class="space-y-6">
          <input type="hidden" name="form-name" value="book-event" />

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-rizq-gold text-xs uppercase tracking-[0.2em] mb-2">Your Name</label>
              <input type="text" name="name" required class="w-full bg-transparent border-b border-rizq-cream/20 text-rizq-cream py-2 focus:border-rizq-gold focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-rizq-gold text-xs uppercase tracking-[0.2em] mb-2">Phone</label>
              <input type="tel" name="phone" required class="w-full bg-transparent border-b border-rizq-cream/20 text-rizq-cream py-2 focus:border-rizq-gold focus:outline-none transition-colors" />
            </div>
          </div>

          <div>
            <label class="block text-rizq-gold text-xs uppercase tracking-[0.2em] mb-2">Email</label>
            <input type="email" name="email" required class="w-full bg-transparent border-b border-rizq-cream/20 text-rizq-cream py-2 focus:border-rizq-gold focus:outline-none transition-colors" />
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-rizq-gold text-xs uppercase tracking-[0.2em] mb-2">Event Type</label>
              <select name="event_type" required class="w-full bg-rizq-charcoal-soft border-b border-rizq-cream/20 text-rizq-cream py-2 focus:border-rizq-gold focus:outline-none">
                <option value="">Select</option>
                <option>Wedding Ceremony</option>
                <option>Social Event</option>
                <option>Corporate Event</option>
                <option>Industrial Catering</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="block text-rizq-gold text-xs uppercase tracking-[0.2em] mb-2">Guest Count</label>
              <input type="number" name="guests" min="50" placeholder="50+" class="w-full bg-transparent border-b border-rizq-cream/20 text-rizq-cream py-2 focus:border-rizq-gold focus:outline-none transition-colors" />
            </div>
          </div>

          <div>
            <label class="block text-rizq-gold text-xs uppercase tracking-[0.2em] mb-2">Event Date</label>
            <input type="date" name="date" class="w-full bg-transparent border-b border-rizq-cream/20 text-rizq-cream py-2 focus:border-rizq-gold focus:outline-none transition-colors" />
          </div>

          <div>
            <label class="block text-rizq-gold text-xs uppercase tracking-[0.2em] mb-2">Tell us more</label>
            <textarea name="message" rows="4" class="w-full bg-transparent border-b border-rizq-cream/20 text-rizq-cream py-2 focus:border-rizq-gold focus:outline-none transition-colors resize-none"></textarea>
          </div>

          <button type="submit" class="magnetic w-full px-10 py-4 bg-rizq-red text-white uppercase tracking-[0.2em] text-sm font-semibold hover:shadow-[0_15px_40px_rgba(220,38,38,0.5)] transition-all duration-300">
            Submit Inquiry
          </button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
