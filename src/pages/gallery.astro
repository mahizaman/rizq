---
import Layout from "../layouts/Layout.astro";

// Replace these with your real photo filenames in /public/gallery/
const photos = [
  { src: "/gallery/1.jpg", caption: "Royal Walima Setup" },
  { src: "/gallery/2.jpg", caption: "Signature Kacchi" },
  { src: "/gallery/3.jpg", caption: "Corporate Gala" },
  { src: "/gallery/4.jpg", caption: "Mehendi Ceremony" },
  { src: "/gallery/5.jpg", caption: "Live BBQ Counter" },
  { src: "/gallery/6.jpg", caption: "Anniversary Gala" },
  { src: "/gallery/7.jpg", caption: "Premium Plating" },
  { src: "/gallery/8.jpg", caption: "Product Launch" },
  { src: "/gallery/9.jpg", caption: "Industrial Catering" },
];
---

<Layout title="Gallery — Rizq Catering">
  <!-- Header -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-royal to-royal-dark text-white text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-crimson uppercase tracking-[0.3em] text-sm font-semibold mb-4">Gallery</p>
      <h1 class="font-display text-4xl md:text-6xl mb-6 leading-tight">
        Moments We've Created
      </h1>
      <p class="text-ivory/80 text-lg md:text-xl max-w-2xl mx-auto">
        A glimpse into the events, dishes, and experiences that define Rizq.
      </p>
    </div>
  </section>

  <!-- Masonry-style grid -->
  <section class="py-20 px-6 bg-ivory">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {
          photos.map((photo, i) => (
            <div
              class={`group relative overflow-hidden rounded-xl bg-gradient-to-br from-royal to-charcoal cursor-pointer ${
                i % 5 === 0 ? "row-span-2 aspect-[3/5]" : "aspect-square"
              }`}
            >
              <img
                src={photo.src}
                alt={photo.caption}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                onerror="this.style.display='none'"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                <p class="text-white font-display text-lg">{photo.caption}</p>
              </div>
            </div>
          ))
        }
      </div>

      <p class="text-center text-charcoal-light mt-12 italic">
        More moments coming soon. Follow us on social media for the latest events.
      </p>
    </div>
  </section>
</Layout>
