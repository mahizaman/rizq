---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config/site.js";

const callForPrice = (item) =>
  `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(`Hello Rizq, I'd like to inquire about pricing for "${item}".`)}`;

const bestSellers = [
  {
    name: "Signature Kacchi Gourmet",
    description: "Aromatic basmati rice slow-cooked with premium mutton, saffron, and traditional spices — Rizq's crown jewel.",
    image: "/menu-kacchi.jpg",
    tag: "Signature",
  },
  {
    name: "Royal Beef Roast",
    description: "Slow-roasted beef in rich, savory spices — a centerpiece of grandeur.",
    image: "/menu-roast.jpg",
    tag: "Best Seller",
  },
  {
    name: "Mughlai Chicken Roast",
    description: "Tender whole chicken roasted in classic Mughlai style, served with fragrant herbs.",
    image: "/menu-chicken.jpg",
    tag: "Best Seller",
  },
  {
    name: "Premium Mutton Rezala",
    description: "Creamy, fragrant mutton curry — refined elegance on every plate.",
    image: "/menu-rezala.jpg",
    tag: "Premium",
  },
  {
    name: "Borhani & Firni Set",
    description: "Traditional mint yogurt drink paired with creamy rice pudding — a quintessential finish.",
    image: "/menu-dessert.jpg",
    tag: "Classic",
  },
  {
    name: "Live BBQ Counter",
    description: "On-site grilling station with kebabs, tikka, and signature roasts — a showstopper for any event.",
    image: "/menu-bbq.jpg",
    tag: "Experience",
  },
];

const customPackages = [
  {
    name: "The Mehendi Package",
    description: "Curated for intimate pre-wedding gatherings — featuring traditional Bengali appetizers, signature mains, and elegant desserts.",
    tag: "Wedding",
  },
  {
    name: "The Walima Grand",
    description: "Royal-scale wedding feast — Kacchi, multiple roasts, live counters, and full service for 500-10,000 guests.",
    tag: "Wedding",
  },
  {
    name: "Corporate Gala Package",
    description: "International-standard buffet with fusion options, designed for VIP clients and executive audiences.",
    tag: "Corporate",
  },
  {
    name: "Anniversary & Milestone",
    description: "Bespoke menus for private celebrations — refined plating, signature dishes, and white-glove service.",
    tag: "Social",
  },
  {
    name: "Industrial Daily Catering",
    description: "Premium daily meals at scale — nutritious, fresh, and reliable for workforces of 500-10,000.",
    tag: "Industrial",
  },
  {
    name: "Bespoke Curation",
    description: "Have a unique vision? We design custom menus from scratch — fusion, international, or specific dietary needs.",
    tag: "Custom",
  },
];
---

<Layout title="The Menus — Rizq Catering">
  <!-- Header -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-royal to-royal-dark text-white text-center">
    <div class="max-w-4xl mx-auto">
      <p class="text-crimson uppercase tracking-[0.3em] text-sm font-semibold mb-4">The Menus</p>
      <h1 class="font-display text-4xl md:text-6xl mb-6 leading-tight">
        Crafted to Impress
      </h1>
      <p class="text-ivory/80 text-lg md:text-xl max-w-2xl mx-auto">
        Explore our signature best sellers and fully customizable packages.
      </p>
    </div>
  </section>

  <!-- Best Sellers -->
  <section class="py-20 px-6 bg-ivory">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-crimson uppercase tracking-[0.25em] text-sm font-semibold mb-3">Best Sellers</p>
        <h2 class="font-display text-4xl md:text-5xl text-royal">Signature Dishes</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          bestSellers.map((item) => (
            <div class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all hover:-translate-y-2 flex flex-col">
              <div class="aspect-[4/3] relative bg-gradient-to-br from-royal to-charcoal overflow-hidden">
                <img
                  src={item.image}
                  alt={item.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror="this.style.display='none'"
                />
                <span class="absolute top-4 left-4 bg-crimson text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
                  {item.tag}
                </span>
              </div>
              <div class="p-6 flex flex-col flex-1">
                <h3 class="font-display text-2xl text-royal mb-3">{item.name}</h3>
                <p class="text-charcoal-light leading-relaxed mb-6 flex-1">{item.description}</p>
                <a
                  href={callForPrice(item.name)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 bg-charcoal hover:bg-royal text-white font-semibold px-5 py-3 rounded-full transition-all"
                >
                  📞 Call for Price
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Custom Packages -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-crimson uppercase tracking-[0.25em] text-sm font-semibold mb-3">Custom Packages</p>
        <h2 class="font-display text-4xl md:text-5xl text-royal">Tailored to Your Event</h2>
        <p class="text-charcoal-light max-w-2xl mx-auto mt-4 text-lg">
          Every package is a starting point — fully customizable to your vision.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          customPackages.map((pkg) => (
            <div class="group bg-ivory rounded-2xl p-7 border border-ivory-dark hover:shadow-xl hover:border-crimson transition-all hover:-translate-y-1 flex flex-col">
              <span class="self-start bg-royal/10 text-royal text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4">
                {pkg.tag}
              </span>
              <h3 class="font-display text-2xl text-royal mb-3">{pkg.name}</h3>
              <p class="text-charcoal-light leading-relaxed mb-6 flex-1">{pkg.description}</p>
              <a
                href={callForPrice(pkg.name)}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-crimson hover:bg-crimson-dark text-white font-semibold px-5 py-3 rounded-full transition-all"
              >
                📞 Call for Price
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
