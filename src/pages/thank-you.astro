---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Thank You — Rizq Catering">
  <section class="min-h-[80vh] flex items-center justify-center px-6 py-32">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-7xl mb-6">🎉</div>
      <h1 class="font-display text-4xl md:text-6xl text-royal mb-6 leading-tight">
        Thank You!
      </h1>
      <p class="text-xl text-charcoal-light mb-10 leading-relaxed">
        Your inquiry has been received. Our team will reach out within 24 hours to begin curating your event.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-crimson hover:bg-crimson-dark text-white font-semibold px-8 py-4 rounded-full transition-all shadow-md hover:shadow-xl"
      >
        ← Back to Home
      </a>
    </div>
  </section>
</Layout>
